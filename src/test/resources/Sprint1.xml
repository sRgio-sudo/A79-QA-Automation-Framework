<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd" >

<suite name="Sprint1" parallel="methods" thread-count="1">
    <listeners>
        <listener class-name="utils.TestListener"/>
    </listeners>
    <parameter name="BaseURL" value="https://qa.koel.app/"/>
    <test name="Smoke Test" preserve-order="true">
        <classes>
            <class name="Tests.LoginTests">
                <methods>
                    <include name="successfulRegistrationAndVerifyDb"/>
                    <include name="registerWithExistedEmail"/>
                    <include name="registerWithInvalidEmail"/>
                    <include name="checkIncorrectCharachters"/>
                </methods>
            </class>
            <class name="Tests.PlayListTests">
                <methods>
                    <include name="checkPlaylist"/>
                    <include name="checkPlayListSameName"/>
                    <include name="checkPlayListNameParameters"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>