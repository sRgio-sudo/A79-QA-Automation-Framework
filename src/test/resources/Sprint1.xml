<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd" >

<suite name="Sprint1">
    <listeners>
        <listener class-name="utils.TestListener"/>
    </listeners>
    <parameter name="BaseURL" value="https://qa.koel.app/"/>
    <test name="Sprint1 Tests" parallel="methods" thread-count="2">
        <classes>
            <class name="Tests.LoginTests">
                <methods>
                    <include name="successfulRegistrationAndVerifyDb"/>
                    <include name="registerWithExistedEmail"/>
                    <include name="registerWithInvalidEmailScenarios"/>
                </methods>
            </class>
            <class name="Tests.PlayListTests">
                <methods>
                    <include name="createPlayListAndVerifyInDb"/>
                    <include name="checkPlayListDuplicateName"/>
                    <include name="checkPlayListNameParameters"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Sequential Profile Tests" parallel="none">
        <classes>
            <class name="Tests.ProfilePageTest">
                <methods>
                    <include name="verifyPasswordHashChangedInDb"/>
                    <include name="changePassword"/>
                    <include name="checkPasswordValidation"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>