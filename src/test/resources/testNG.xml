<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd" >

<suite name="Regression" parallel="methods" thread-count="1">
    <listeners>
        <listener class-name="utils.TestListener"/>
    </listeners>
    <parameter name="BaseURL" value="https://qa.koel.app/"/>
    <test name="Regression Test" preserve-order="true">
        <classes>
            <class name="tests.ui.PlayListTests">
                <methods>
                    <include name="checkFavoritesDownload"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>