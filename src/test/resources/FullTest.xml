<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd" >

<suite name="PlayerTest" parallel="methods" thread-count="2">
    <listeners>
        <listener class-name="utils.TestListener"/>
    </listeners>
    <parameter name="BaseURL" value="https://qa.koel.app/"/>
    <test name="FullTest" preserve-order="false">
        <classes>
            <class name="tests.ui.LoginTests"/>
            <class name="tests.ui.PlayerTests"/>
            <class name="tests.ui.PlayListTests"/>
            <class name="tests.ui.ProfilePageTest"/>
        </classes>
    </test>
</suite>